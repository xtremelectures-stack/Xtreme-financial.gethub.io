/* General Layout */
body { 
    font-family: 'Segoe UI', Arial, sans-serif; 
    margin: 0; 
    color: #333; 
    line-height: 1.6;
}

/* Header */
header { 
    background-color: #002d5b; 
    color: white; 
    padding: 20px; 
    text-align: center; 
}

/* Hero Section */
.hero { 
    padding: 60px 20px; 
    text-align: center; 
    background-color: #f4f7f6; 
}
.hero h1 { 
    color: #002d5b; 
    margin-bottom: 10px;
}

/* Mission Section */
.mission { 
    padding: 40px; 
    max-width: 800px; 
    margin: auto; 
    text-align: center; 
}

/* Footer */
footer { 
    text-align: center; 
    padding: 20px; 
    font-size: 0.8em; 
    color: #777; 
    border-top: 1px solid #ddd;
}
